#!/usr/bin/env bash
# session-context — lean UserPromptSubmit hook with caching
# Cache: full detection runs once per session, then reuses output
set -euo pipefail

CACHE_FILE=".claude/.session-skills.cache"
INPUT=$(cat)
PROMPT=$(jq -r '.prompt // .message // .userPrompt // empty' <<< "$INPUT" 2>/dev/null || true)
[ -z "${PROMPT:-}" ] && exit 0

LOWER=$(printf '%s' "$PROMPT" | tr '[:upper:]' '[:lower:]' | sed -E 's/[[:space:]]+/ /g')
esc() { local s="$1"; s="${s//\\/\\\\}"; s="${s//\"/\\\"}"; s="${s//$'\n'/\\n}"; printf '%s' "$s"; }
has() { printf '%s' "$LOWER" | grep -qiE "\b($1)\b"; }

# ── CACHE CHECK ────────────────────────────────────────────────
CACHE_AGE=$([ -f "$CACHE_FILE" ] && echo $(( $(date +%s) - $(stat -c%Y "$CACHE_FILE" 2>/dev/null || echo 0) )) || echo 3601)
if [ "$CACHE_AGE" -lt 3600 ]; then
    CTX=$(cat "$CACHE_FILE" 2>/dev/null || true)
    if [ -n "$CTX" ]; then
        WARN=""; SEV="low"
        has 'rf.*/ | rm.*-rf.*/ | rm.*-rf.*~' && WARN="Destructive file op" && SEV="critical"
        has 'force.*push.*main|reset.*main.*--hard' && WARN="Destructive git" && SEV="critical"
        has 'drop.*table.*prod|drop.*database' && WARN="Destructive DB" && SEV="critical"
        has 'print.*env.*token|echo.*password|cat.*\.env|commit.*secret' && WARN="Secret exposure" && SEV="high"
        if [ -n "$WARN" ]; then
            printf '{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":"%s","systemMessage":"%s"}}\n' "$(esc "$CTX")" "$(esc "⚠ coder-workflow security [${SEV}]: ${WARN}")"
        else
            printf '{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":"%s"}}\n' "$(esc "$CTX")"
        fi
        exit 0
    fi
fi

# ── FULL DETECTION (cache miss) ────────────────────────────────

SKILLS=""
_intent=""
_add() { local s="$1" i="$2"; [ -n "$SKILLS" ] && SKILLS="${SKILLS},${s}" || SKILLS="$s"; [ -n "$_intent" ] && _intent="${_intent},${i}" || _intent="$i"; }

has 'deploy|deployment|docker|traefik|vps|ci.cd|github.*action|container|compose|nginx|containerize|dockerize|kubernetes|k8s|helm|terraform' && _add "deploy-docker" "deploy"
has 'refactor|refactoring|reorganize|restructure|extract|modular|modularize|mvc|rewrite|cleanup|layer.*separation|susun.*ulang|struktur.*ulang|rapikan|solid|dry|yagni' && _add "refraktor" "refactor"
has 'audit|review|assess|evaluate|inspect|layer.*violation|fat.*controller|coupling|circular.*dependency|code.*smell|cek.*struktur|kelemahan|weakness|quality|kualitas|health' && _add "auditor" "audit"
has 'implement|create|add|build|develop|buat|bikin|tambah|endpoint|route|handler|controller|service|repository|component|api|function|class|module|pagination|cursor|migration' && _add "coder" "implement"
has 'fix|bug|patch|repair|resolve|debug|troubleshoot|perbaiki|benahi|error|crash|broken|fail|gagal|exception|panic|segfault|null|undefined|race.condition|memory.*leak|timeout' && _add "coder" "implement"
has 'brainstorm|design|spec|idea|requirement|fitur|rekomendasi|solution.*approach|alternatif|trade.?off' && _add "brainstorming" "brainstorm"
has 'plan|roadmap|decompose|break.*down|strategy|steps|rencana|tahapan|langkah|task|subtask|milestone|sprint|backlog' && _add "planner" "plan"
has 'test|testing|unit.*test|integration.*test|e2e|coverage|mock|stub|assert|tdd|bdd|uji|pengujian|vitest|jest|mocha|pytest|playwright|cypress' && _add "tester" "test"
has 'diagram|visual|visualization|mermaid|graph.*viz|arsitektur.*diagram|module.*map|dependency.*graph|call.*graph' && _add "diagram" "diagram"
has 'doc|documentation|readme|readme|pr.*description|changelog|release.*note|adr|contributing|migration.*guide|api.*spec|openapi|swagger' && _add "docs" "docs"
has 'memory|lesson|learn|experience|journal|knowledge|cross.?agent|store.*lesson|simpan.*pelajaran|ingat' && _add "memory" "memory"
has 'secrets|api.*key|token|password|credential|private.*key|certificate.*pem|secret.*scan|hardcoded.*credential|env.*file|.env' && _add "secrets" "security"
has 'vuln|vulnerability|cve|sbom|supply.*chain|dependency.*check|snyk|npm.*audit' && _add "vuln" "security"
has 'dead.*code|unused.*export|orphan.*file|uncalled.*function|tree.?shake|mati.*kode|tak.*terpakai' && _add "deadcode" "audit"
has 'performance|perf|bundle.*size|lighthouse|load.*time|slow.*query|n+1|index.*strategy|optimization|optimasi|cepat|lambat' && _add "performance" "perf"
has 'docker|compose|container|vps|server.*production|ci.cd|github.*action|deploy|traefik|nginx|ghcr|production' && [ -z "$SKILLS" ] && _add "deploy-docker" "deploy"

[ -z "$SKILLS" ] && SKILLS="none" && _intent="unknown"

# Security checks
WARN=""; SEV="low"
_add_warn() { local m="$1" s="$2"; WARN="${WARN}${m} "; [ "$s" = "critical" ] && SEV="critical" || [ "$s" = "high" ] && [ "$SEV" != "critical" ] && SEV="high"; }
has 'rf.*/ | rm.*-rf.*/ | rm.*-rf.*~|hapus.*semua.*file|delete.*all.*file|wipe.*filesystem|format.*disk' && _add_warn "Destructive file op" "critical"
has 'force.*push.*main|force.*push.*master|push.*-f.*main|reset.*main.*--hard|delete.*git.*history' && _add_warn "Destructive git" "critical"
has 'drop.*table.*prod|drop.*database.*prod|truncate.*all|hancurkan.*database' && _add_warn "Destructive DB" "critical"
has 'print.*env.*token|echo.*password|cat.*\.env|commit.*secret|upload.*secret|commit.*private.*key' && _add_warn "Secret exposure" "high"
has 'deploy.*prod|push.*production|live.*server|production.*database|migrate.*prod' && _add_warn "Production targeting" "high"

# Language, complexity
LANG="en"
printf '%s' "$LOWER" | grep -qE '(kerjakan|implementasi|perbaiki|buat|tambah|apa|bagaimana|jelaskan|fitur|kode|saya|kita|tolong|bisa|analisis|kelemahan|cek|susun|struktur|rapikan)' && LANG="id"
WORD_COUNT=$(printf '%s' "$PROMPT" | wc -w | tr -d ' ')
COMPLEXITY="simple"
printf '%s' "$LOWER" | grep -qiE '\b(multi|architecture|migration|platform|scalab|distribut|event.*driven|refactor|restructure|modular|multiple.*module|schema.*design|auth|authentication|authorization)\b' && COMPLEXITY="complex"
printf '%s' "$LOWER" | grep -qiE '\b(feature|endpoint|service|repository|controller|module|komponen|fitur)\b' && [ "$WORD_COUNT" -gt 20 ] && COMPLEXITY="standard"
[ "$WORD_COUNT" -gt 150 ] && COMPLEXITY="complex"
[ "$WORD_COUNT" -gt 50 ] && [ "$COMPLEXITY" = "simple" ] && COMPLEXITY="standard"

PRIMARY=$(printf '%s' "$_intent" | cut -d',' -f1)
[ -z "$PRIMARY" ] && PRIMARY="unknown"

CTX="coder-workflow: skills=[${SKILLS}], intents=[${_intent}], primary=${PRIMARY} (confidence=simple), complexity=${COMPLEXITY}, lang=${LANG}, words=${WORD_COUNT}. CRITICAL RULE: You MUST use TaskCreate and TaskUpdate immediately to track all work. Never ignore task tools."
[ -n "$WARN" ] && CTX="${CTX} SECURITY[${SEV}]: ${WARN}"
CTX_E=$(esc "$CTX")

if [ -n "$WARN" ]; then
    W=$(esc "⚠ coder-workflow security [${SEV}]: ${WARN}")
    printf '{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":"%s","systemMessage":"%s"}}\n' "$CTX_E" "$W"
else
    printf '{"hookSpecificOutput":{"hookEventName":"UserPromptSubmit","additionalContext":"%s"}}\n' "$CTX_E"
fi

# Write cache for next call
mkdir -p .claude 2>/dev/null || true
printf '%s' "$CTX" > "$CACHE_FILE" 2>/dev/null || true
exit 0
