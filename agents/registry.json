    "architecture-auditor": {
      "file": "agents/architecture-auditor.md",
      "role": "audit",
      "description": "Read-only architecture audit - graph-first layer violation detection",
      "tools": [
        "Read",
        "Grep",
        "Glob",
        "mcp__codegraph__*",
        "invoke_subagent"
      ],
      "model": "sonnet"
    },
