{
  "name": "coder-workflow",
  "version": "0.3.0",
  "type": "module",
  "bin": {
    "coder-workflow": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    ".claude-plugin",
    ".cursor-plugin",
    "gemini-extension.json",
    ".mcp.json",
    "agents",
    "hooks",
    "skills",
    "commands",
    "docs",
    "CLAUDE.md",
    "README.md",
    "install.sh",
    "install.ps1"
  ],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "test": "npm run build && npm run typecheck && node --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test \"dist/test/**/*.test.js\" \"dist/test/*.test.js\" \"test/**/*.test.mjs\" \"test/*.test.mjs\"",
    "start:mcp": "node dist/mcp-server.js",
    "scan": "node dist/cli.js scan",
    "ui": "node dist/cli.js ui",
    "dashboard": "node dist/cli.js dashboard",
    "lint": "biome check src test package.json tsconfig.json biome.json esbuild.config.mjs",
    "format": "biome format --write src test package.json tsconfig.json biome.json esbuild.config.mjs",
    "check": "biome check --write src test package.json tsconfig.json biome.json esbuild.config.mjs",
    "install:global": "./install.sh",
    "install:project": "./install.sh --project",
    "install:link": "./install.sh --link"
  },
  "dependencies": {
    "@libsql/client": "^0.8.0",
    "@modelcontextprotocol/sdk": "latest",
    "@types/node": "latest",
    "blessed": "^0.1.81",
    "typescript": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/blessed": "^0.1.27",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0"
  },
  "description": "Orchestrator-driven coding workflow with graph-first codebase understanding — task decomposition, skill routing, architecture audit, Docker deploy, and CodeGraph MCP server.",
  "author": {
    "name": "Asep Haryana",
    "email": "asepharyana71@gmail.com"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "coding-workflow",
    "planning",
    "refactoring",
    "modular-mvc",
    "architecture-audit",
    "service-repository",
    "orchestrator",
    "task-decomposition",
    "skill-routing",
    "mcp-first",
    "learning-first",
    "codegraph-first",
    "codegraph",
    "architecture",
    "static-analysis",
    "dependency-graph",
    "visualization",
    "code-search",
    "codebase-understanding",
    "impact-analysis",
    "call-graph",
    "graph-first",
    "codebase-routing"
  ]
}
